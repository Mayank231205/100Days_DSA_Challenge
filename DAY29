#include <stdio.h>
#include <stdlib.h>

struct Node {
    int data;
    struct Node* next;
};

int main() {
    int n, k, i;

    struct Node *head = NULL, *temp = NULL, *newNode;

    printf("Enter number of nodes: ");
    scanf("%d", &n);

    printf("Enter %d elements:\n", n);

    for(i = 0; i < n; i++) {
        newNode = (struct Node*)malloc(sizeof(struct Node));

        scanf("%d", &newNode->data);
        newNode->next = NULL;

        if(head == NULL) {
            head = newNode;
            temp = newNode;
        } else {
            temp->next = newNode;
            temp = newNode;
        }
    }

    printf("Enter rotation value k: ");
    scanf("%d", &k);

    // Find last node
    temp->next = head;   // make circular

    k = k % n;
    int steps = n - k;

    struct Node *ptr = head;

    for(i = 1; i < steps; i++) {
        ptr = ptr->next;
    }

    head = ptr->next;
    ptr->next = NULL;

    printf("Rotated List: ");

    struct Node *p = head;
    while(p != NULL) {
        printf("%d ", p->data);
        p = p->next;
    }

    printf("\n");

    system("pause");
    return 0;
}
