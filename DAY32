#include <stdio.h>
#include <stdlib.h>

#define MAX 100

int stack[MAX];
int top = -1;

void push(int value) {
    if(top == MAX - 1) {
        printf("Stack Overflow\n");
        return;
    }
    top++;
    stack[top] = value;
}

void pop() {
    if(top == -1) {
        printf("Stack Underflow\n");
        return;
    }
    top--;
}

void display() {
    if(top == -1) {
        printf("Stack Empty\n");
        return;
    }

    printf("Remaining stack (top to bottom): ");

    for(int i = top; i >= 0; i--) {
        printf("%d ", stack[i]);
    }
}

int main() {

    int n, m, i, value;

    printf("Enter number of elements to push: ");
    scanf("%d", &n);

    printf("Enter %d elements:\n", n);

    for(i = 0; i < n; i++) {
        scanf("%d", &value);
        push(value);
    }

    printf("Enter number of pops: ");
    scanf("%d", &m);

    for(i = 0; i < m; i++) {
        pop();
    }

    display();

    printf("\n");

    system("pause");
    return 0;
}
